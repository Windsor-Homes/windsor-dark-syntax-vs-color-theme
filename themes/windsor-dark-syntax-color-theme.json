{
	"$schema": "vscode://schemas/color-theme",
	"name": "Windsor Dark",
	"type": "dark",
	"colors": {
		// Activity bar and badges
		"activityBar.background": "#333842",
		"activityBar.foreground": "#d7dae0",
		"activityBarBadge.background": "#528bff",
		"activityBarBadge.foreground": "#d7dae0",
		"badge.background": "#528bff",
		"badge.foreground": "#d7dae0",

		// Buttons and inputs
		"button.background": "#4d78cc",
		"button.foreground": "#ffffff",
		"button.hoverBackground": "#6087cf",
		"dropdown.background": "#353b45",
		"dropdown.border": "#181a1f",
		"input.background": "#1b1d23",
		"input.border": "#181a1f",
 
		// Editor surface
		"editor.background": "#212121",
		"editor.foreground": "#a8a8a8",
		"editor.selectionBackground": "#3e4451",
		"editor.lineHighlightBackground": "#99bbff0a",
		"editor.findMatchHighlightBackground": "#528bff3d",
		"editorCursor.foreground": "#528bff",
		"editorLineNumber.foreground": "#424242",
		"editorLineNumber.activeForeground": "#bdbdbd",
		"editorWhitespace.foreground": "#abb2bf26",
		"editorRuler.foreground": "#abb2bf26",
		"editorPane.background": "#212121",

		// Editor widgets and groups
		"editorGroup.border": "#181a1f",
		"editorGroupHeader.tabsBackground": "#191919",
		"editorHoverWidget.background": "#21252b",
		"editorHoverWidget.border": "#181a1f",
		"editorWidget.background": "#21252b",
		"editorWidget.border": "#3a3f4b",
		"editorSuggestWidget.background": "#21252b",
		"editorSuggestWidget.border": "#181a1f",
		"editorSuggestWidget.selectedBackground": "#2c313a",
		"editorInlayHint.background": "#2c313a",
		"editorInlayHint.foreground": "#636e83",

		// Lists and sidebars
		"sideBar.background": "#21252b",
		"sideBarSectionHeader.background": "#333842",
		"list.activeSelectionBackground": "#2c313a",
		"list.activeSelectionForeground": "#d7dae0",
		"list.focusBackground": "#2c313a",
		"list.highlightForeground": "#d7dae0",
		"list.hoverBackground": "#2c313a66",
		"list.inactiveSelectionBackground": "#2c313a",
		"list.inactiveSelectionForeground": "#d7dae0",

		// Tabs and title/status bars
		"tab.activeBackground": "#212121",
		"tab.activeForeground": "#d7dae0",
		"tab.border": "#181a1f",
		"tab.inactiveBackground": "#191919",
		"tab.inactiveForeground": "#a8a8a8",
		"titleBar.activeBackground": "#21252b",
		"titleBar.activeForeground": "#9da5b4",
		"titleBar.inactiveBackground": "#21252b",
		"titleBar.inactiveForeground": "#9da5b4",
		"statusBar.background": "#21252b",
		"statusBar.foreground": "#9da5b4",
		"statusBar.debuggingForeground": "#ffffff",
		"statusBar.noFolderBackground": "#21252b",
		"statusBarItem.hoverBackground": "#2c313a",

		// Panels and peek
		"peekView.border": "#528bff",
		"peekViewEditor.background": "#1b1d23",
		"peekViewResult.background": "#21252b",
		"peekViewResult.selectionBackground": "#2c313a",
		"peekViewTitle.background": "#1b1d23",
		"pickerGroup.border": "#528bff",

		// Misc
		"focusBorder": "#528bff",
		"diffEditor.insertedTextBackground": "#00809b33",
		"notebook.cellEditorBackground": "#2c313a",
		"scrollbarSlider.background": "#4e566680",
		"scrollbarSlider.hoverBackground": "#5a637580",
		"scrollbarSlider.activeBackground": "#747d9180",
		"extensionButton.prominentBackground": "#2ba143",
		"extensionButton.prominentHoverBackground": "#37af4e"
	},
	"tokenColors": [
		// Neutrals
		{
			"scope": [
				"customrule",
				"meta.class.body",
				"meta.definition.property.js variable",
				"meta.definition.property.ts variable",
				"meta.definition.property.jsx variable",
				"meta.definition.property.tsx variable",
				"meta.tag",
				"meta.separator",
				"meta.method",
				"meta.method-call",
				"none",
				"punctuation.definition.array",
				"punctuation.definition.function-parameters",
				"punctuation.definition.method-parameters",
				"punctuation.definition.parameters",
				"punctuation.definition.seperator",
				"punctuation.definition.separator",
				"punctuation.separator.annotation.python",
				"punctuation.separator.parameters.python",
				"source.css property-name.support",
				"source.css property-value.support",
				"source.elixir source.embedded.source",
				"source.java-properties meta.key-pair > punctuation",
				"source.php class.bracket",
				"storage.modifier.lifetime.rust",
				"support.constant.property-value.css",
				"support.type.property-name"
			],
			"settings": { "foreground": "#ABB2BF" }
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": { "foreground": "#607D8B" }
		},

		// Keyword family
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator",
				"keyword.operator.expression.in.js",
				"keyword.operator.expression.in.jsx",
				"keyword.operator.expression.in.ts",
				"keyword.operator.expression.in.tsx",
				"keyword.operator.expression.instanceof.js",
				"keyword.operator.expression.instanceof.ts",
				"keyword.operator.expression.instanceof.tsx",
				"keyword.operator.expression.of.js",
				"keyword.operator.expression.of.ts",
				"keyword.operator.expression.of.tsx",
				"keyword.other.unsafe.rust",
				"source.c keyword.operator",
				"source.cpp keyword.operator",
				"source.go storage.type.string",
				"source.java keyword.operator.instanceof",
				"source.python keyword.operator.logical.python",
				"source.elixir variable.definition",
				"source.elixir variable.anonymous"
			],
			"settings": { "foreground": "#C678DD" }
		},
		{
			"scope": [
				"keyword - keyword.operator",
				"keyword.blade",
				"keyword.control",
				"keyword.operator",
				"keyword.operator.logical",
				"keyword.other",
				"keyword.other.unit",
				"keyword.sql",
				"storage.modifier",
				"storage.type",
				"entity.name.tag"
			],
			"settings": { "foreground": "#F44336" }
		},

		// Functions and declarations
		{
			"scope": [
				"entity.name.function",
				"entity.name.section",
				"entity.other.attribute-name.id",
				"entity.name.variable.property.cs",
				"punctuation.definition.heading",
				"punctuation.definition.identity",
				"support.function.any-method"
			],
			"settings": { "foreground": "#61AFEF" }
		},
		{
			"scope": [
				"entity.name.class",
				"entity.name.type",
				"entity.name.type.class",
				"meta.class",
				"storage.type.cs",
				"storage.type.primitive.array.java",
				"support.class"
			],
			"settings": { "foreground": "#E5C07B" }
		},
		{
			"scope": [
				"entity.name.class",
				"entity.name.type.class",
				"entity.other.attribute-name.pseudo-class.css",
				"support.class",
				"constant.other.database-name"
			],
			"settings": { "foreground": "#0091EA", "fontStyle": "bold" }
		},
		{
			"scope": "support.function",
			"settings": { "foreground": "#0091EA", "fontStyle": "italic" }
		},

		// Variables and properties
		{
			"scope": [
				"variable",
				"variable.other",
				"variable.other.property",
				"variable.other.global",
				"variable.other.readwrite.cs",
				"variable.other.object.cs",
				"variable.other.object.property.cs",
				"support.variable.magic.python"
			],
			"settings": { "foreground": "#E06C75" }
		},
		{
			"scope": [
				"entity.other.attribute-name",
				"meta.function.parameters.python",
				"source.python variable.parameter",
				"support.constant",
				"variable.other.constant.ruby"
			],
			"settings": { "foreground": "#D19A66" }
		},
		{
			"scope": [
				"variable.language.this",
				"entity.other.attribute-name.class.css"
			],
			"settings": { "foreground": "#F57C00", "fontStyle": "bold" }
		},

		// Strings and constants
		{
			"scope": [
				"string",
				"markup.inline.raw.markdown",
				"markup.inserted"
			],
			"settings": { "foreground": "#98C379" }
		},
		{
			"scope": [
				"string.quoted.single",
				"string.quoted.double"
			],
			"settings": { "foreground": "#FFD600" }
		},
		{
			"scope": [
				"constant",
				"constant.character.escape",
				"constant.language",
				"constant.numeric",
				"constant.other",
				"support.constant"
			],
			"settings": { "foreground": "#8B86C6" }
		},
		{
			"scope": "constant.other.color",
			"settings": { "foreground": "#FFD600", "fontStyle": "italic" }
		},

		// Punctuation and structural accents
		{
			"scope": "punctuation.section.embedded",
			"settings": { "foreground": "#EA1C0D" }
		},
		{
			"scope": [
				"entity.name.type.namespace",
				"punctuation.definition.class",
				"punctuation.definition.storage-type",
				"punctuation.section.array",
				"punctuation.separator.inheritance",
				"punctuation.separator.key-value"
			],
			"settings": { "foreground": "#0091EA" }
		},
		{
			"scope": [
				"punctuation.definition.arguments",
				"support.type.property-name.css",
				"support.type.property-name.media.css",
				"support.type.vendored.property-name.css"
			],
			"settings": { "foreground": "#00C853" }
		},

		// Markdown
		{
			"scope": [
				"entity.name.section.markdown",
				"punctuation.definition.heading.markdown",
				"beginning.punctuation.definition.list.markdown"
			],
			"settings": { "foreground": "#E06C75" }
		},
		{
			"scope": [
				"markup.quote.markdown",
				"comment"
			],
			"settings": { "foreground": "#5C6370", "fontStyle": "italic" }
		},

		// Diagnostics tokens
		{ "scope": "token.info-token", "settings": { "foreground": "#6796E6" } },
		{ "scope": "token.warn-token", "settings": { "foreground": "#CD9731" } },
		{ "scope": "token.error-token", "settings": { "foreground": "#F44747" } },
		{ "scope": "token.debug-token", "settings": { "foreground": "#B267E6" } }
	]
}
